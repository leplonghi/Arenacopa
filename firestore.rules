rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBolaoCreator(bolaoId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/boloes/$(bolaoId)).data.creator_id == request.auth.uid;
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId);
    }

    match /boloes/{bolaoId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.creator_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.creator_id == request.auth.uid;
    }

    match /bolao_members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /bolao_palpites/{palpiteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /bolao_markets/{marketId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isBolaoCreator(request.resource.data.bolao_id);
      allow update, delete: if isSignedIn() && isBolaoCreator(resource.data.bolao_id);
    }

    match /bolao_predictions/{predictionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /bolao_onboarding_state/{stateId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /bolao_activity/{activityId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /bolao_champion_predictions/{predictionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /bolao_extra_bets/{betId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /native_push_tokens/{tokenId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /push_subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    match /premium_subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    match /bolao_rankings/{rankingId} {
      allow read: if true;
      allow write: if false;
    }

    match /copa_news/{newsId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
