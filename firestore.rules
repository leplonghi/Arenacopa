rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isBolaoMember(bolaoId) {
      return exists(/databases/$(database)/documents/bolao_members/$(request.auth.uid + '_' + bolaoId));
    }

    function isBolaoMemberAfter(bolaoId) {
      return existsAfter(/databases/$(database)/documents/bolao_members/$(request.auth.uid + '_' + bolaoId));
    }

    function isBolaoCreator(bolaoId) {
      return get(/databases/$(database)/documents/boloes/$(bolaoId)).data.creator_id == request.auth.uid;
    }

    function isBolaoCreatorAfter(bolaoId) {
      return existsAfter(/databases/$(database)/documents/boloes/$(bolaoId)) &&
        getAfter(/databases/$(database)/documents/boloes/$(bolaoId)).data.creator_id == request.auth.uid;
    }

    function getBolao(bolaoId) {
      return get(/databases/$(database)/documents/boloes/$(bolaoId)).data;
    }

    function canSelfJoinBolao(bolaoId) {
      let bolao = getBolao(bolaoId);
      return bolao.status in ['open', 'active'] && (
        bolao.category == 'public' ||
        (
          request.resource.data.invite_code is string &&
          request.resource.data.invite_code == bolao.invite_code
        )
      );
    }

    function isGrupoMember(grupoId) {
      return exists(/databases/$(database)/documents/grupo_members/$(request.auth.uid + '_' + grupoId));
    }

    function isGrupoCreator(grupoId) {
      return get(/databases/$(database)/documents/grupos/$(grupoId)).data.creator_id == request.auth.uid;
    }

    function isGrupoCreatorAfter(grupoId) {
      return existsAfter(/databases/$(database)/documents/grupos/$(grupoId)) &&
        getAfter(/databases/$(database)/documents/grupos/$(grupoId)).data.creator_id == request.auth.uid;
    }

    function getGrupo(grupoId) {
      return get(/databases/$(database)/documents/grupos/$(grupoId)).data;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function isPresentationOnlyBolaoUpdate() {
      return changedKeys().hasOnly([
        "name",
        "description",
        "avatar_url",
        "invite_message",
        "updated_at",
        "audit_meta"
      ]);
    }

    function canSelfJoinGrupo(grupoId) {
      let grupo = getGrupo(grupoId);
      return grupo.category == 'public' ||
        (
          request.resource.data.invite_code is string &&
          request.resource.data.invite_code == grupo.invite_code
        );
    }

    // profiles
    match /profiles/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // public_profiles — sanitized public identity only
    match /public_profiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
        isOwner(userId) &&
        request.resource.data.user_id == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'user_id',
          'name',
          'nickname',
          'avatar_url',
          'created_at',
          'updated_at'
        ]);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // matches — public read, only Firebase Admin SDK can write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // copa_news — public read, only Firebase Admin SDK can write
    match /copa_news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    // news — championship feeds, public read
    match /news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    // news_sources — public catalog, only Admin SDK writes
    match /news_sources/{sourceId} {
      allow read: if true;
      allow write: if false;
    }

    // news_articles — normalized news feed for app
    match /news_articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    // news_links_by_championship — aggregated links by championship
    match /news_links_by_championship/{championshipId} {
      allow read: if true;
      allow write: if false;
    }

    // news_fetch_runs / news_raw — server-only operational collections
    match /news_fetch_runs/{runId} {
      allow read, write: if false;
    }

    match /news_raw/{rawId} {
      allow read, write: if false;
    }

    // standings — public read, only Admin SDK writes
    match /standings/{standingId} {
      allow read: if true;
      allow write: if false;
    }

    // teams — public read, only Admin SDK writes
    match /teams/{teamId} {
      allow read: if true;
      allow write: if false;
    }

    // boloes
    match /boloes/{bolaoId} {
      allow read: if isSignedIn() && (
        resource.data.category == 'public' ||
        isBolaoMember(bolaoId) ||
        isOwner(resource.data.creator_id)
      );
      allow create: if isSignedIn() && isOwner(request.resource.data.creator_id);
      allow update: if isSignedIn() &&
        isOwner(resource.data.creator_id) &&
        isPresentationOnlyBolaoUpdate();
      allow delete: if isSignedIn() && isOwner(resource.data.creator_id);
    }

    // bolao_members
    match /bolao_members/{memberId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isBolaoMember(resource.data.bolao_id)
      );
      allow create: if isSignedIn() && (
        (
          isOwner(request.resource.data.user_id) &&
          memberId == request.auth.uid + '_' + request.resource.data.bolao_id &&
          request.resource.data.role == 'member' &&
          request.resource.data.payment_status == 'pending' &&
          canSelfJoinBolao(request.resource.data.bolao_id)
        ) ||
        (
          (isBolaoCreator(request.resource.data.bolao_id) || isBolaoCreatorAfter(request.resource.data.bolao_id)) &&
          request.resource.data.role in ['member', 'admin'] &&
          request.resource.data.user_id is string
        )
      );
      allow update: if false;
      allow delete: if false;
    }

    // bolao_markets
    match /bolao_markets/{marketId} {
      allow read: if isSignedIn() && (
        isBolaoMember(resource.data.bolao_id) ||
        isBolaoCreator(resource.data.bolao_id)
      );
      allow create: if isSignedIn() && (
        isBolaoCreator(request.resource.data.bolao_id) ||
        isBolaoCreatorAfter(request.resource.data.bolao_id)
      );
      allow update, delete: if isSignedIn() && isBolaoCreator(resource.data.bolao_id);
    }

    // bolao_activity — generated by backend, readable by participants
    match /bolao_activity/{activityId} {
      allow read: if isSignedIn() && (
        isBolaoMember(resource.data.bolao_id) ||
        isBolaoCreator(resource.data.bolao_id)
      );
      allow write: if false;
    }

    // bolao_extra_bets — legacy mirror for tournament-wide extras
    match /bolao_extra_bets/{extraId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isBolaoCreator(resource.data.bolao_id)
      );
      allow create: if isSignedIn() &&
        isOwner(request.resource.data.user_id) &&
        request.resource.data.user_id == request.auth.uid &&
        isBolaoMember(request.resource.data.bolao_id);
      allow update: if isSignedIn() &&
        isOwner(resource.data.user_id) &&
        request.resource.data.user_id == resource.data.user_id &&
        request.resource.data.bolao_id == resource.data.bolao_id &&
        request.resource.data.category == resource.data.category;
      allow delete: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isBolaoCreator(resource.data.bolao_id)
      );
    }

    // bolao_palpites
    match /bolao_palpites/{palpiteId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isBolaoMember(resource.data.bolao_id)
      );
      allow create: if isSignedIn() &&
        isOwner(request.resource.data.user_id) &&
        isBolaoMember(request.resource.data.bolao_id) &&
        request.resource.data.points == null &&
        request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn() &&
        isOwner(resource.data.user_id) &&
        resource.data.points == null &&
        request.resource.data.user_id == resource.data.user_id &&
        request.resource.data.bolao_id == resource.data.bolao_id &&
        request.resource.data.match_id == resource.data.match_id &&
        request.resource.data.points == resource.data.points;
      allow delete: if isSignedIn() && isOwner(resource.data.user_id);
    }

    // bolao_predictions
    match /bolao_predictions/{predictionId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isBolaoMember(resource.data.bolao_id)
      );
      allow create: if isSignedIn() &&
        isOwner(request.resource.data.user_id) &&
        isBolaoMember(request.resource.data.bolao_id) &&
        request.resource.data.user_id == request.auth.uid &&
        request.resource.data.points_awarded == null &&
        request.resource.data.resolved == false;
      allow update: if isSignedIn() &&
        isOwner(resource.data.user_id) &&
        resource.data.resolved == false &&
        request.resource.data.user_id == resource.data.user_id &&
        request.resource.data.bolao_id == resource.data.bolao_id &&
        request.resource.data.market_id == resource.data.market_id &&
        request.resource.data.points_awarded == resource.data.points_awarded &&
        request.resource.data.resolved == resource.data.resolved;
      allow delete: if isSignedIn() && isOwner(resource.data.user_id);
    }

    // bolao_champion_predictions
    match /bolao_champion_predictions/{predId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isBolaoMember(resource.data.bolao_id)
      );
      allow create, update: if isSignedIn() &&
        isOwner(request.resource.data.user_id) &&
        (
          isBolaoMember(request.resource.data.bolao_id) ||
          isBolaoMemberAfter(request.resource.data.bolao_id) ||
          isBolaoCreatorAfter(request.resource.data.bolao_id)
        ) &&
        request.resource.data.user_id == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(resource.data.user_id);
    }

    // bolao_rankings — only Admin SDK writes
    match /bolao_rankings/{rankingId} {
      allow read: if isSignedIn() && isBolaoMember(resource.data.bolao_id);
      allow write: if false;
    }

    // bolao_onboarding_state
    match /bolao_onboarding_state/{stateId} {
      allow create: if isSignedIn() && isOwner(request.resource.data.user_id);
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.user_id);
    }

    // notifications
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && isOwner(resource.data.user_id);
      allow create: if false;
      allow delete: if isSignedIn() && isOwner(resource.data.user_id);
    }

    // push_subscriptions
    match /push_subscriptions/{subId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data.user_id);
      allow create, update: if isSignedIn() && isOwner(request.resource.data.user_id);
    }

    // native_push_tokens
    match /native_push_tokens/{tokenId} {
      allow read, delete: if isSignedIn() && isOwner(resource.data.user_id);
      allow create, update: if isSignedIn() && isOwner(request.resource.data.user_id);
    }

    // premium_subscriptions — only Admin SDK writes
    match /premium_subscriptions/{subId} {
      allow read: if isSignedIn() && isOwner(resource.data.user_id);
      allow write: if false;
    }

    // grupos
    match /grupos/{grupoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.creator_id);
      allow update, delete: if isSignedIn() && isOwner(resource.data.creator_id);
    }

    // grupo_members
    match /grupo_members/{memberId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isGrupoMember(resource.data.grupo_id) ||
        isGrupoCreator(resource.data.grupo_id)
      );
      allow create: if isSignedIn() && (
        (
          isOwner(request.resource.data.user_id) &&
          memberId == request.auth.uid + '_' + request.resource.data.grupo_id &&
          request.resource.data.role == 'member' &&
          canSelfJoinGrupo(request.resource.data.grupo_id)
        ) ||
        (
          isOwner(request.resource.data.user_id) &&
          memberId == request.auth.uid + '_' + request.resource.data.grupo_id &&
          request.resource.data.role == 'admin' &&
          (
            isGrupoCreator(request.resource.data.grupo_id) ||
            isGrupoCreatorAfter(request.resource.data.grupo_id)
          )
        ) ||
        (
          (
            isGrupoCreator(request.resource.data.grupo_id) ||
            isGrupoCreatorAfter(request.resource.data.grupo_id)
          ) &&
          request.resource.data.role in ['member', 'admin'] &&
          request.resource.data.user_id is string
        )
      );
      allow update: if isSignedIn() && isGrupoCreator(resource.data.grupo_id);
      allow delete: if isSignedIn() && (
        isOwner(resource.data.user_id) ||
        isGrupoCreator(resource.data.grupo_id)
      );
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
