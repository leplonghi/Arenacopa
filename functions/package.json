{
    "name": "arenacup-functions",
    "version": "1.0.0",
    "description": "Firebase Cloud Functions for ArenaCup App (Gamification and Push Notifications)",
    "engines": {
        "node": "20"
    },
    "main": "index.js",
    "dependencies": {
        "firebase-admin": "^12.0.0",
        "firebase-functions": "^5.0.0",
        "rss-parser": "^3.13.0"
    },
    "scripts": {
        "serve": "firebase serve --only functions",
        "shell": "firebase functions:shell",
        "start": "npm run shell",
